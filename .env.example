# ─── PROVEEDOR DE IA ────────────────────────────────────────
# Opciones: "gemini" (GRATIS, recomendado para demo) | "claude" (de pago)
AI_PROVIDER=gemini

# ─── GEMINI (Google AI Studio — GRATIS) ─────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
# Límites gratuitos: 15 req/min, 1500 req/día — suficiente para demo
GEMINI_API_KEY=AIzaSy...tu_clave_aqui

# ─── CLAUDE (Anthropic — de pago, ~$0.001/imagen con Haiku) ──
# Obtener en: https://console.anthropic.com
# Descomentá y cambiá AI_PROVIDER=claude cuando quieras activarlo
# ANTHROPIC_API_KEY=sk-ant-...tu_clave_aqui

# ─── NOTA SOBRE MERCADOLIBRE ────────────────────────────────
# La API de búsqueda de ML es PÚBLICA y GRATUITA.
# No requiere ninguna API key.
# El proxy en /api/ml.js resuelve el problema de CORS.
